---

<div class="fixed right-5 bottom-8 z-40 flex flex-col items-center gap-2">
  <!-- Vertical line above -->
  <div class="w-px h-10 bg-surface-border mb-1"></div>

  {links.map(({ href, label, icon }) => (
    <a
      href={href}
      aria-label={label}
      target={href.startsWith('http') ? '_blank' : undefined}
      rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
      class="w-10 h-10 flex items-center justify-center rounded-full bg-primary text-white hover:bg-primary-dark transition-all duration-200 shadow-md"
    >
      <Fragment set:html={icon} />
    </a>
  ))}
</div>

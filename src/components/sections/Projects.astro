---
import ProjectCard from '@/components/ui/ProjectCard.astro';
import { t } from '@/i18n/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
const tr = t('en');

const filters = [
  { key: 'all',      label: tr.projects.filters.all },
  { key: 'jam',      label: tr.projects.filters.jam },
  { key: 'personal', label: tr.projects.filters.personal },
  { key: 'academic', label: tr.projects.filters.academic },
];
---

<section id="projects" class="section-padding">
  <div class="container-max">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <h2 class="text-4xl md:text-5xl font-black">{tr.projects.title}</h2>

      <!-- Filter tabs -->
      <div id="project-filters" class="flex flex-wrap gap-2">
        {filters.map(({ key, label }) => (
          <button
            data-filter={key}
            class:list={[
              'filter-btn font-sans text-xs px-4 py-2 rounded-full border transition-all duration-200',
              key === 'all'
                ? 'bg-primary text-white border-primary'
                : 'border-surface-border text-text-muted hover:border-primary hover:text-primary',
            ]}
          >
            {label}
          </button>
        ))}
      </div>
    </div>

    <!-- Grid -->
    <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>

    <!-- More projects -->
    <div class="mt-16 pt-10 border-t border-surface-border flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <span class="font-mono text-xs text-text-muted uppercase tracking-widest shrink-0">
        More projects on
      </span>
      <div class="flex items-center gap-4">
        <a
          href="https://edorinc.itch.io/"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 font-sans text-sm font-semibold text-text-muted hover:text-primary transition-colors duration-200"
        >
          <svg width="16" height="16" viewBox="0 0 245 245" fill="currentColor" aria-hidden="true">
            <path d="M31.99 7.781C21.161 14.041 0 39.57 0 45.069v9.3c0 11.7 10.993 21.994 20.98 21.994 11.993 0 22.02-10.028 22.02-21.994 0 11.966 9.496 21.994 21.489 21.994s21.027-10.028 21.027-21.994c0 11.966 10.026 21.994 22.02 21.994 11.992 0 21.488-10.028 21.488-21.994 0 11.966 9.498 21.994 21.491 21.994 11.992 0 21.489-10.028 21.489-21.994 0 11.966 9.028 21.994 21.02 21.994 11.993 0 22.02-10.028 22.02-21.994 0 11.966 10.027 21.994 22.02 21.994C244.008 76.363 245 66.069 245 54.369v-9.3c0-5.499-21.161-31.028-31.989-37.288C196.018.49 181.025 0 122.5 0S49.982.49 31.99 7.781zM68 87.725v.01c-3.496.67-6.765 1.804-9.74 3.293v.006C46.33 97.282 38 109.156 38 124.4v74.937l2.967 2.602C54.994 213.944 95.517 228 122.5 228s67.505-14.056 81.533-26.061L207 199.337V124.4c0-15.244-8.33-27.118-20.26-33.366v-.006a40.743 40.743 0 0 0-9.74-3.293v-.01c-2.91-.55-6.07-.95-9.5-1.125v-.006H77.5v.006c-3.43.175-6.59.575-9.5 1.119zM94 116h57c12.15 0 22 9.85 22 22v11H72v-11c0-12.15 9.85-22 22-22zm-22 55h101v8c0 11.254-6.594 20-18 24.938V204c0 6.627-5.373 12-12 12H102c-6.627 0-12-5.373-12-12v-.063C78.594 199 72 190.254 72 179v-8z"/>
          </svg>
          itch.io ↗
        </a>
        <span class="text-surface-border">·</span>
        <a
          href="https://github.com/EdorInc"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 font-sans text-sm font-semibold text-text-muted hover:text-primary transition-colors duration-200"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub ↗
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards   = document.querySelectorAll<HTMLElement>('[data-category]');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      // Reset all to inactive
      buttons.forEach((b) => {
        b.classList.remove('bg-primary', 'text-white', 'border-primary');
        b.classList.add('border-surface-border', 'text-text-muted', 'hover:border-primary', 'hover:text-primary');
      });
      // Set clicked button as active
      btn.classList.add('bg-primary', 'text-white', 'border-primary');
      btn.classList.remove('border-surface-border', 'text-text-muted', 'hover:border-primary', 'hover:text-primary');

      // Filter cards
      cards.forEach((card) => {
        const show = filter === 'all' || card.dataset.category === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>
